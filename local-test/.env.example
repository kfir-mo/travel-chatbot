# WordPress Configuration
WP_URL=https://your-wordpress-site.com
WP_USERNAME=your-wp-username
WP_APP_PASSWORD=your-14-char-app-password

# AI Provider (openai or claude)
AI_PROVIDER=claude
AI_KEY=your-api-key-here
AI_MODEL=claude-3-5-sonnet-20241022

# Optional: For OpenAI
# OPENAI_KEY=your-openai-key
# OPENAI_MODEL=gpt-4-turbo

# Affiliate/External Services
SKYSCANNER_ID=your-skyscanner-id
BOOKING_COM_ID=your-booking-id
SECRETFLIGHTS_KEY=your-secretflights-key
SECRETFLIGHTS_URL=https://api.secretflights.co.il

# Server
PORT=3000
NODE_ENV=development
