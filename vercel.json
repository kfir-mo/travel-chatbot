{
  "version": 2,
  "buildCommand": "mkdir -p public",
  "outputDirectory": ".",
  "public": false,
  "functions": {
    "api/chat.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/chat.js"
    }
  ]
}
