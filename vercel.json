{
  "version": 2,
  "buildCommand": "mkdir -p public",
  "outputDirectory": ".",
  "public": false,
  "functions": {
    "api/chat.js": {
      "memory": 1024,
      "maxDuration": 30
    },
    "api/status.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/config.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/api/chat",
      "dest": "/api/chat.js"
    },
    {
      "src": "/status",
      "dest": "/api/status.js"
    },
    {
      "src": "/config",
      "dest": "/api/config.js"
    },
    {
      "src": "/(.*)",
      "dest": "/api/chat.js"
    }
  ]
}
